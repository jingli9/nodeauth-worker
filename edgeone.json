{
  "name": "nodeauth-worker",
  "installCommand": "npm install",
  "buildCommand": "node scripts/inject_vars.js --platform=edgeone",
  "outputDirectory": "frontend/dist",
  "nodeVersion": "24.5.0",
  "schedules": [
    {
      "name": "daily-backup",
      "cron": "0 2 * * *",
      "path": "/api/cron/backup",
      "method": "POST"
    }
  ],
  "cloudFunctions": {
    "nodejs": {
      "externalNodeModules": [
        "cloudflare:sockets"
      ],
      "includeFiles": [
        "cloud-functions/**",
        "frontend/**",
        "edgeone.json",
        "package.json",
        "package-lock.json",
        "scripts/inject_vars.js"
      ],
      "maxDuration": 120
    }
  }
}